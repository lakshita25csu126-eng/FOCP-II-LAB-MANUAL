class Solution {
public:
 string cleanString(string s) {
    string result = "";

    for (int i = 0; i < s.length(); i++) {
        char c = s[i];

        if (isalnum((unsigned char)c)) {
            result += tolower((unsigned char)c);
        }
    }
    return result;
}

    bool isPalindrome(string s) {
        s = cleanString(s);

        string rev = string(s.rbegin(), s.rend());
        return s == rev;
    }
};
